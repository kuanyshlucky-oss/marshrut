# Пример переменных окружения. Скопируйте в .env для локального запуска.

# Порт, на котором слушает сервер
PORT=8080

# Путь к файлу базы SQLite
DB_PATH=data/marshrut.db

# Секрет для подписи токенов — ОБЯЗАТЕЛЬНО задайте свой длинный случайный на проде
JWT_SECRET=change-me-to-a-long-random-string

# Домен фронтенда для CORS (в проде — адрес GitHub Pages).
# Для локальной разработки можно оставить *
ALLOWED_ORIGIN=https://kuanyshlucky-oss.github.io
